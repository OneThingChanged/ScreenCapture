{
  "name": "screen-capture",
  "version": "0.1.3",
  "description": "Windows screen capture, recording, media management, and editing app",
  "main": "out/main/index.js",
  "author": "jintae",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit --composite false -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit --composite false -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pack": "electron-vite build && node scripts/package.mjs",
    "pack:installer": "electron-vite build && electron-builder --win --publish never",
    "release:build": "electron-vite build && electron-builder --win --publish never",
    "icon": "node resources/generate-icon.mjs && node resources/png-to-ico.mjs"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "fabric": "^7.4.0",
    "typescript": "^5.6.3",
    "vite": "^7.3.6"
  },
  "dependencies": {
    "@fluentui/react-icons": "^2.0.333",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
